<Window x:Class="VideoEditor.Views.PublishingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI Publisher" Height="820" Width="550"
        Background="{StaticResource PrimaryBackground}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Platform Selection -->
            <RowDefinition Height="*"/>    <!-- Metadata Fields -->
            <RowDefinition Height="Auto"/> <!-- Progress -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="AI Publisher" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
            <TextBlock Text="Optimize your video with AI and publish to social media." 
                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Platform Selection & Account -->
        <Border Grid.Row="1" Background="{StaticResource SecondaryBackground}" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Target Platform" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <ComboBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}"
                          Margin="0,0,0,10"/>

                <StackPanel Visibility="{Binding SelectedPlatform, Converter={StaticResource StringComparisonVisibilityConverter}, ConverterParameter=YouTube}">
                    <TextBlock Text="Publish Preset" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                              Margin="0,0,0,10"/>
                </StackPanel>

                <!-- YouTube Account Section -->
                <StackPanel Visibility="{Binding SelectedPlatform, Converter={StaticResource StringComparisonVisibilityConverter}, ConverterParameter=YouTube}">
                    <Separator Background="#33FFFFFF" Margin="0,5,0,10"/>
                    
                    <!-- Not Logged In -->
                    <Grid Visibility="{Binding IsYouTubeLoggedIn, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Account not connected" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <Button Grid.Column="1" Content="Login to YouTube" Command="{Binding LoginYouTubeCommand}"
                                Style="{StaticResource ModernButton}" Padding="15,5" FontSize="12" Background="#CCFF0000"/>
                    </Grid>

                    <!-- Logged In -->
                    <Grid Visibility="{Binding IsYouTubeLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="32" Height="32" Margin="0,0,12,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ChannelThumbnail}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Connected Channel" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="{Binding ChannelName}" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Switch" Command="{Binding LoginYouTubeCommand}"
                                Style="{StaticResource ModernButton}" Background="Transparent" 
                                BorderBrush="#33FFFFFF" BorderThickness="1" Padding="10,2" FontSize="10"/>
                    </Grid>

                    <StackPanel Margin="0,15,0,0" Visibility="{Binding IsYouTubeLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Privacy Status" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding PrivacyStatuses}" SelectedItem="{Binding SelectedPrivacyStatus}"
                                  Padding="8" Background="Black" Foreground="White" BorderBrush="#33FFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Metadata Fields -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Content Metadata" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="✨ Generate with AI" Command="{Binding GenerateAIMetadataCommand}"
                            Style="{StaticResource ModernButton}" HorizontalAlignment="Right"
                            Padding="12,5" Background="#1A00C1D4" FontSize="11" IsEnabled="{Binding IsGenerating, Converter={StaticResource InvertBooleanConverter}}"/>
                </DockPanel>

                <TextBlock Text="Title" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Title}" Margin="0,0,0,15" Padding="10" Background="Black" Foreground="White" 
                         BorderBrush="#33FFFFFF" FontSize="14" FontWeight="Bold"/>

                <TextBlock Text="Description" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Description}" Margin="0,0,0,15" Padding="10" Background="Black" Foreground="White" 
                         BorderBrush="#33FFFFFF" TextWrapping="Wrap" AcceptsReturn="True" Height="150" VerticalContentAlignment="Top"/>

                <TextBlock Text="Tags / Keywords" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Tags}" Margin="0,0,0,5" Padding="10" Background="Black" Foreground="White" 
                         BorderBrush="#33FFFFFF" TextWrapping="Wrap" Height="60"/>
                <TextBlock Text="Separate tags with commas" FontSize="9" Foreground="{StaticResource TextSecondary}" Margin="2,0,0,15"/>

                <!-- ══ Thumbnail Picker (YouTube only) ══════════════════════ -->
                <StackPanel Visibility="{Binding SelectedPlatform,
                                Converter={StaticResource StringComparisonVisibilityConverter},
                                ConverterParameter=YouTube}">

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Thumbnail" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="OPTIONAL" FontSize="9" Foreground="{StaticResource AccentColor}"
                                   FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Preview box -->
                    <Border CornerRadius="6" BorderBrush="#33FFFFFF" BorderThickness="1"
                            Background="#0D0D0D" Height="160" Margin="0,0,0,8"
                            ClipToBounds="True">
                        <!-- Placeholder when no thumbnail is chosen -->
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding HasThumbnail,
                                            Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                <TextBlock Text="🖼️" FontSize="36" HorizontalAlignment="Center"/>
                                <TextBlock Text="No thumbnail selected" FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock Text="Recommended: 1280 × 720 px  ·  JPG or PNG  ·  Max 2 MB"
                                           FontSize="10" Foreground="#555555"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Actual preview image -->
                            <Image Visibility="{Binding HasThumbnail,
                                       Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Source="{Binding ThumbnailPath}"
                                   Stretch="UniformToFill"/>

                            <!-- Overlay badge -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="6" Background="#CC000000" CornerRadius="3" Padding="5,2"
                                    Visibility="{Binding HasThumbnail,
                                        Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="✔ Custom Thumbnail" FontSize="10"
                                           Foreground="#2ECC71" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Browse + Clear row -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="📂  Choose Image..."
                                Command="{Binding BrowseThumbnailCommand}"
                                Style="{StaticResource ModernButton}"
                                Padding="14,8" FontSize="13"/>

                        <Button Grid.Column="1" Content="✕ Clear"
                                Command="{Binding ClearThumbnailCommand}"
                                Visibility="{Binding HasThumbnail,
                                    Converter={StaticResource BooleanToVisibilityConverter}}"
                                Style="{StaticResource ModernButton}"
                                Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1"
                                Margin="8,0,0,0" Padding="12,8" FontSize="13"/>
                    </Grid>

                    <TextBlock FontSize="10" Foreground="#555555" TextWrapping="Wrap" Margin="2,0,0,0">
                        <Run Text="⚠ Custom thumbnails require a "/>
                        <Run Text="verified YouTube account" FontWeight="Bold" Foreground="#888"/>
                        <Run Text=". If upload fails, set it manually in YouTube Studio."/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Progress -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20" Visibility="{Binding IsPublishing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!-- Export Progress -->
            <StackPanel Visibility="{Binding IsExporting, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,10">
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Exporting Video..." FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="{Binding ExportProgress, StringFormat={}{0}%}" HorizontalAlignment="Right" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                </Grid>
                <ProgressBar Value="{Binding ExportProgress}" Height="6" Background="Black" Foreground="{StaticResource AccentColor}" BorderThickness="0"/>
            </StackPanel>

            <!-- Upload Progress -->
            <StackPanel Visibility="{Binding IsExporting, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                <Grid Margin="0,0,0,5">
                    <TextBlock Text="Uploading to YouTube..." FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="{Binding PublishProgress, StringFormat={}{0}%}" HorizontalAlignment="Right" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                </Grid>
                <ProgressBar Value="{Binding PublishProgress}" Height="6" Background="Black" Foreground="{StaticResource AccentColor}" BorderThickness="0"/>
            </StackPanel>
            
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource AccentColor}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Actions -->
        <Grid Grid.Row="4">
            <!-- Standard Actions -->
            <Grid Visibility="{Binding IsSuccess, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Cancel" IsEnabled="{Binding IsPublishing, Converter={StaticResource InvertBooleanConverter}}"
                        Style="{StaticResource ModernButton}" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1"
                        Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Grid.Column="1" Content="Publish to Social Media" Height="50" FontSize="18" FontWeight="Bold"
                        Style="{StaticResource ModernButton}" Command="{Binding PublishCommand}"
                        IsEnabled="{Binding IsPublishing, Converter={StaticResource InvertBooleanConverter}}"/>
            </Grid>

            <!-- Success Actions -->
            <Grid Visibility="{Binding IsSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Open Link" Command="{Binding OpenInYouTubeCommand}"
                        Style="{StaticResource ModernButton}" Background="#1A00C1D4" Margin="0,0,10,0"/>
                <Button Grid.Column="1" Content="Copy Link" Command="{Binding CopyLinkCommand}"
                        Style="{StaticResource ModernButton}" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="Close" Click="Cancel_Click"
                        Style="{StaticResource ModernButton}" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
