<Window x:Class="VideoEditor.Views.AppSplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EditNovaFX"
        Height="420" Width="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Fade-in animation for the whole window -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"
                             EasingFunction="{x:Null}"/>
        </Storyboard>

        <!-- Fade-out animation triggered just before close -->
        <Storyboard x:Key="FadeOutStoryboard" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.4"/>
        </Storyboard>

        <!-- Progress bar fill animation (0→100% in ~2.8 s) -->
        <Storyboard x:Key="ProgressStoryboard">
            <DoubleAnimation Storyboard.TargetName="ProgressFill"
                             Storyboard.TargetProperty="Width"
                             From="0" To="580" Duration="0:0:2.8"
                             EasingFunction="{x:Null}"/>
        </Storyboard>

        <!-- Logo pulse -->
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"/>
        </Storyboard>
    </Window.Resources>

    <!-- Root border — clipped with rounded corners, drop shadow for elevation -->
    <Border x:Name="RootBorder" CornerRadius="12" Opacity="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.7" ShadowDepth="6" Direction="270" Color="#000000"/>
        </Border.Effect>

        <Border CornerRadius="12" ClipToBounds="True">
            <!-- Deep dark background with subtle gradient -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#111318" Offset="0"/>
                        <GradientStop Color="#181C24" Offset="0.6"/>
                        <GradientStop Color="#1A1E28" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- ── Decorative accent stripe top-left ── -->
                <Rectangle VerticalAlignment="Top" HorizontalAlignment="Left"
                           Width="4" Height="420" Opacity="0.9">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#007ACC" Offset="0"/>
                            <GradientStop Color="#00B4FF" Offset="0.5"/>
                            <GradientStop Color="#007ACC" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- ── Decorative light beam (top-right glow) ── -->
                <Ellipse HorizontalAlignment="Right" VerticalAlignment="Top"
                         Width="400" Height="300" Margin="0,-100,-100,0" Opacity="0.06">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#007ACC" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- ── Film-strip dot grid (subtle texture) ── -->
                <Canvas Opacity="0.04" ClipToBounds="True" Width="680" Height="420">
                    <Rectangle Canvas.Left="40"  Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="120" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="200" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="280" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="360" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="440" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="520" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="600" Canvas.Top="30"  Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="40"  Canvas.Top="100" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="600" Canvas.Top="100" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="40"  Canvas.Top="170" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="600" Canvas.Top="170" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="40"  Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="120" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="200" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="280" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="360" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="440" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="520" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                    <Rectangle Canvas.Left="600" Canvas.Top="390" Width="3" Height="3" Fill="White" RadiusX="1" RadiusY="1"/>
                </Canvas>

                <!-- ── Main content stack ── -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="50,0">

                    <!-- Icon / Logo area -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,22">
                        <!-- Outer glow ring -->
                        <Ellipse x:Name="LogoGlow" Width="100" Height="100" Opacity="0.5">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#007ACC" Offset="0.3"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Main Image Logo -->
                        <Image Source="/Assets/app_logo.png" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#007ACC" Opacity="0.5" ShadowDepth="0"/>
                            </Image.Effect>
                        </Image>
                    </Grid>

                    <!-- App name -->
                    <TextBlock Text="EditNovaFX"
                               FontSize="38"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#C8E8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#007ACC" Opacity="0.3" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Tagline -->
                    <TextBlock Text="Professional Video Editor"
                               FontSize="13"
                               FontFamily="Segoe UI"
                               FontWeight="Light"
                               HorizontalAlignment="Center"
                               Foreground="#7AACCC"
                               Margin="0,4,0,0"/>

                    <!-- Thin separator line -->
                    <Rectangle Height="1" Width="280" Margin="0,22,0,22" HorizontalAlignment="Center" Opacity="0.25">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#007ACC" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Feature pills row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Border Background="#1A2A38" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="🎬  Multi-track" FontSize="11" Foreground="#7AACCC" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#1A2A38" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="🤖  AI Subtitles" FontSize="11" Foreground="#7AACCC" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#1A2A38" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="📤  4K Export" FontSize="11" Foreground="#7AACCC" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#1A2A38" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="🚀  YouTube" FontSize="11" Foreground="#7AACCC" FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>

                    <!-- Progress bar track -->
                    <Border CornerRadius="4" Width="580" Height="4" Background="#1E2830" Margin="0,0,0,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" Color="#007ACC" Opacity="0.2" ShadowDepth="0"/>
                        </Border.Effect>
                        <Grid HorizontalAlignment="Left">
                            <!-- Animated fill -->
                            <Rectangle x:Name="ProgressFill" Height="4" Width="0"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       RadiusX="4" RadiusY="4">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#005F99" Offset="0"/>
                                        <GradientStop Color="#007ACC" Offset="0.5"/>
                                        <GradientStop Color="#00C2FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.Effect>
                                    <DropShadowEffect BlurRadius="6" Color="#00AAFF" Opacity="0.8" ShadowDepth="0"/>
                                </Rectangle.Effect>
                            </Rectangle>
                        </Grid>
                    </Border>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusText"
                               Text="Initialising…"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               Foreground="#446070"
                               HorizontalAlignment="Center"/>

                </StackPanel>

                <!-- Bottom bar: version + studio name -->
                <Grid VerticalAlignment="Bottom" Margin="20,0,20,14">
                    <TextBlock Text="v1.0.0"
                               FontSize="10" FontFamily="Segoe UI"
                               Foreground="#2A4A5A"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="© 2026 NLCI Lab"
                               FontSize="10" FontFamily="Segoe UI"
                               Foreground="#2A4A5A"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>
