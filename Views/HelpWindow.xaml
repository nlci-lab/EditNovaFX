<Window x:Class="VideoEditor.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VideoEditor.ViewModels"
        xmlns:models="clr-namespace:VideoEditor.Models"
        Title="Help Center - EditNovaFX" 
        Height="720" Width="1050"
        Background="{StaticResource PrimaryBackground}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow">

    <Window.DataContext>
        <vm:HelpViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <!-- ════════════════════════════════════════
             STEP CARD STYLE
             ════════════════════════════════════════ -->
        <Style x:Key="StepCard" TargetType="Border">
            <Setter Property="Background" Value="#1C2A3A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#2A4A6A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Step number badge -->
        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CornerRadius" Value="17"/>
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Tip box -->
        <Style x:Key="TipBox" TargetType="Border">
            <Setter Property="Background" Value="#1A3A2A"/>
            <Setter Property="BorderBrush" Value="#2ECC71"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <!-- Warning box -->
        <Style x:Key="WarningBox" TargetType="Border">
            <Setter Property="Background" Value="#3A2A1A"/>
            <Setter Property="BorderBrush" Value="#E67E22"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <!-- Section heading text -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,20,0,8"/>
        </Style>

        <!-- Shortcut key badge -->
        <Style x:Key="KeyBadge" TargetType="Border">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <!-- FAQ question text -->
        <Style x:Key="FaqQuestion" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Screen zone badge -->
        <Style x:Key="ZoneBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ════════════════════════════════════════
             LIST DATA TEMPLATES
             ════════════════════════════════════════ -->

        <!-- HelpStep item template -->
        <DataTemplate x:Key="StepTemplate" DataType="{x:Type models:HelpStep}">
            <Border Style="{StaticResource StepCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="{Binding Number}" Foreground="White" FontWeight="Bold"
                                   FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Emoji}" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Detail}" FontSize="13" Foreground="#CBCBCB"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ShortcutItem template -->
        <DataTemplate x:Key="ShortcutTemplate" DataType="{x:Type models:ShortcutItem}">
            <Border Background="#1A1A1A" CornerRadius="6" Margin="0,0,0,6" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource KeyBadge}" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Keys}" FontFamily="Consolas" FontSize="13"
                                   Foreground="#00C1D4" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding Action}" VerticalAlignment="Center"
                               FontSize="13" Foreground="#DDDDDD"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- FaqItem template -->
        <DataTemplate x:Key="FaqTemplate" DataType="{x:Type models:FaqItem}">
            <Border Background="#1C1C2E" CornerRadius="8" Margin="0,0,0,10" Padding="14,12"
                    BorderBrush="#303050" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="❓" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <TextBlock Text="{Binding Question}" Style="{StaticResource FaqQuestion}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Answer}" FontSize="13" Foreground="#BBBBBB"
                               TextWrapping="Wrap" LineHeight="20" Margin="22,0,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ScreenZone template -->
        <DataTemplate x:Key="ScreenZoneTemplate" DataType="{x:Type models:ScreenZone}">
            <Border CornerRadius="6" Margin="0,0,0,8" Padding="12,8" 
                    Background="{Binding Color}" Opacity="0.9">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#EEEEEE"
                               TextWrapping="Wrap" Opacity="0.9"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════
             LEFT SIDEBAR — Navigation Tree
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#161B22"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="18,18,18,10" 
                        BorderBrush="#2A3A4A" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="📖" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Help Center" FontSize="18" FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="EditNovaFX" FontSize="11" Foreground="#00C1D4"
                                   FontWeight="SemiBold" Margin="28,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Search Box -->
                <Border Grid.Row="1" Margin="12,10,12,6" Background="#0D1117" CornerRadius="6"
                        BorderBrush="#2A3A4A" BorderThickness="1" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" VerticalAlignment="Center"
                                 FontSize="13" CaretBrush="White"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="Watermark" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Search help topics..." Foreground="Gray" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource Watermark}"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="{x:Null}">
                                            <Setter Property="Background" Value="{StaticResource Watermark}"/>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Topics Tree -->
                <TreeView Grid.Row="2" x:Name="TopicsTree" ItemsSource="{Binding Topics}"
                          Background="Transparent" BorderThickness="0"
                          Margin="6,4,6,4"
                          VirtualizingStackPanel.IsVirtualizing="True">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1A3A5A"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1A3A5A"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <EventSetter Event="Selected" Handler="TreeViewItem_Selected"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding SubTopics}">
                            <Border CornerRadius="5" Padding="4,3" Margin="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <!-- Footer -->
                <Border Grid.Row="3" Padding="14,10" BorderBrush="#1A2A3A" BorderThickness="0,1,0,0">
                    <TextBlock Text="EditNovaFX v1.0  ·  NLCI Lab"
                               FontSize="11" Foreground="#445566" TextAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             RIGHT CONTENT PANEL
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="{StaticResource PrimaryBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel x:Name="ContentArea" Margin="36,30,36,40">

                    <!-- ── Topic Header ── -->
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="{Binding SelectedTopic.Icon}" FontSize="44"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SelectedTopic.Title}"
                                   FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource AccentColor}"
                                   TextWrapping="Wrap"/>
                        <Border Height="3" Background="{StaticResource AccentColor}"
                                HorizontalAlignment="Left" Width="50"
                                Margin="0,8,0,0" Opacity="0.7" CornerRadius="2"/>
                    </StackPanel>

                    <!-- ── Summary / Intro ── -->
                    <TextBlock Text="{Binding SelectedTopic.Summary}"
                               FontSize="15" Foreground="#CCCCCC"
                               TextWrapping="Wrap" LineHeight="24"
                               Margin="0,16,0,0"/>

                    <!-- ── Screen Layout Diagram ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.HasScreenDiagram,
                                    Converter={StaticResource BooleanToVisibilityConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="SCREEN LAYOUT" Style="{StaticResource SectionHeading}"/>

                        <!-- Faux screen wireframe -->
                        <Border Background="#0D1117" CornerRadius="10" Padding="10"
                                BorderBrush="#2A3A4A" BorderThickness="1" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition Height="80"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <!-- Menu bar mockup -->
                                <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#1C2A3A" CornerRadius="4,4,0,0">
                                    <TextBlock Text="  File   Edit   Import   Export   Tools   Help"
                                               FontSize="9" Foreground="#6688AA" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Media Library zone -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#1F6B8E" Opacity="0.7"
                                        Margin="2" CornerRadius="3">
                                    <TextBlock Text="① Media" FontSize="9" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>

                                <!-- Preview zone -->
                                <Border Grid.Row="1" Grid.Column="1" Background="#1E6B3A" Opacity="0.7"
                                        Margin="2" CornerRadius="3">
                                    <TextBlock Text="② Preview" FontSize="9" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Properties zone -->
                                <Border Grid.Row="1" Grid.Column="2" Background="#6B3A1E" Opacity="0.7"
                                        Margin="2" CornerRadius="3">
                                    <TextBlock Text="③ Props" FontSize="9" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>

                                <!-- Timeline zone -->
                                <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#4A1E6B" Opacity="0.7"
                                        Margin="2,2,2,0" CornerRadius="3">
                                    <TextBlock Text="④ Timeline" FontSize="9" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Zone legend -->
                        <ItemsControl ItemsSource="{Binding SelectedTopic.ScreenZones}"
                                      ItemTemplate="{StaticResource ScreenZoneTemplate}"/>
                    </StackPanel>

                    <!-- ── Step-by-Step Instructions ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.Steps.Count,
                                    Converter={StaticResource ZeroToCollapsedConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="STEP-BY-STEP GUIDE" Style="{StaticResource SectionHeading}"/>
                        <ItemsControl ItemsSource="{Binding SelectedTopic.Steps}"
                                      ItemTemplate="{StaticResource StepTemplate}"/>
                    </StackPanel>

                    <!-- ── Tips ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.Tips.Count,
                                    Converter={StaticResource ZeroToCollapsedConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="TIPS" Style="{StaticResource SectionHeading}"/>
                        <ItemsControl ItemsSource="{Binding SelectedTopic.Tips}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TipBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#2ECC71" Width="4" CornerRadius="2"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="💡 " FontSize="13" VerticalAlignment="Top"/>
                                            <TextBlock Text="{Binding}" FontSize="13" Foreground="#CCFFCC"
                                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Warnings ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.Warnings.Count,
                                    Converter={StaticResource ZeroToCollapsedConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="IMPORTANT" Style="{StaticResource SectionHeading}"/>
                        <ItemsControl ItemsSource="{Binding SelectedTopic.Warnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WarningBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#E67E22" Width="4" CornerRadius="2"
                                                    Margin="0,0,10,0"/>
                                            <TextBlock Text="⚠️ " FontSize="13" VerticalAlignment="Top"/>
                                            <TextBlock Text="{Binding}" FontSize="13" Foreground="#FFE0B2"
                                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Keyboard Shortcuts Table ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.Shortcuts.Count,
                                    Converter={StaticResource ZeroToCollapsedConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="KEYBOARD SHORTCUTS ⌨️" Style="{StaticResource SectionHeading}"/>
                        <Border Background="#111111" CornerRadius="8" Padding="4"
                                BorderBrush="#2A2A2A" BorderThickness="1">
                            <!-- Header -->
                            <StackPanel>
                                <Grid Margin="12,8,12,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SHORTCUT" FontSize="11" FontWeight="Bold"
                                               Foreground="#555"/>
                                    <TextBlock Grid.Column="1" Text="ACTION" FontSize="11"
                                               FontWeight="Bold" Foreground="#555"/>
                                </Grid>
                                <Border Height="1" Background="#222222" Margin="6,0"/>
                                <ItemsControl ItemsSource="{Binding SelectedTopic.Shortcuts}"
                                              ItemTemplate="{StaticResource ShortcutTemplate}"
                                              Margin="4"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── FAQ ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.Faqs.Count,
                                    Converter={StaticResource ZeroToCollapsedConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="FREQUENTLY ASKED QUESTIONS"
                                   Style="{StaticResource SectionHeading}"/>
                        <ItemsControl ItemsSource="{Binding SelectedTopic.Faqs}"
                                      ItemTemplate="{StaticResource FaqTemplate}"/>
                    </StackPanel>

                    <!-- ── Main Description Content ── -->
                    <StackPanel Visibility="{Binding SelectedTopic.Content,
                                    Converter={StaticResource NotNullToVisibilityConverter},
                                    FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding SelectedTopic.Content}"
                                   FontSize="14" Foreground="#BBBBBB"
                                   TextWrapping="Wrap" LineHeight="22"
                                   Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- ── Persistent pro tip at the bottom (only pages without shortcuts) ── -->
                    <Border Margin="0,32,0,0" Padding="16,12"
                            Background="#0D1A0D" CornerRadius="8"
                            BorderBrush="#2ECC71" BorderThickness="1"
                            Visibility="{Binding SelectedTopic.Shortcuts.Count,
                                Converter={StaticResource ZeroToCollapsedConverter},
                                ConverterParameter=Inverted,
                                FallbackValue=Visible}">
                        <StackPanel>
                            <TextBlock Text="⌨️  Pro Tip" FontWeight="Bold" FontSize="13"
                                       Foreground="#2ECC71" Margin="0,0,0,4"/>
                            <TextBlock Text="Use keyboard shortcuts to speed up your workflow. Press F1 or go to Help → Keyboard Shortcuts to see all available shortcuts."
                                       FontSize="13" Foreground="#99CC99" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>
