<Window x:Class="VideoEditor.Views.YouTubeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YouTube API Setup" Height="450" Width="500"
        Background="{StaticResource PrimaryBackground}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="YouTube API Configuration" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
            <TextBlock Text="Enter your Google Cloud Console credentials to enable publishing." 
                       Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Client ID" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox x:Name="ClientIdBox" Margin="0,0,0,20" Padding="12" Background="Black" Foreground="White" 
                     BorderBrush="#33FFFFFF" FontSize="13" VerticalContentAlignment="Center"/>

            <TextBlock Text="Client Secret" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ClientSecretBox" Margin="0,0,0,20" Padding="12" Background="Black" Foreground="White" 
                         BorderBrush="#33FFFFFF" FontSize="13" VerticalContentAlignment="Center"/>

            <Button Content="How do I get these?" HorizontalAlignment="Left" Background="Transparent" 
                    BorderThickness="0" Foreground="{StaticResource AccentColor}" Cursor="Hand" Click="Help_Click"/>
        </StackPanel>

        <!-- Actions -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Cancel" Style="{StaticResource ModernButton}" Background="Transparent" 
                    BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Grid.Column="1" Content="Save Configuration" Style="{StaticResource ModernButton}" 
                    Height="45" FontSize="14" FontWeight="Bold" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
