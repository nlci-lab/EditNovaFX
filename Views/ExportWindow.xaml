<Window x:Class="VideoEditor.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Export Video" Height="600" Width="480"
        Background="{StaticResource PrimaryBackground}"
        Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Presets List -->
            <RowDefinition Height="Auto"/> <!-- Custom Settings -->
            <RowDefinition Height="Auto"/> <!-- File Output -->
            <RowDefinition Height="Auto"/> <!-- Export Button -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Export &amp; Share" FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
            <TextBlock Text="Choose a preset optimized for your target platform." 
                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Presets List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                 Background="Transparent" BorderThickness="0" Margin="0,0,0,15"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="10" Padding="12" Margin="0,0,0,10"
                                        BorderBrush="#33FFFFFF" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Width="45" Height="45" CornerRadius="8" Background="#22FFFFFF" Margin="0,0,15,0">
                                            <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="White"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Width, StringFormat={}{0}p}" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource AccentColor}"/>
                                            <TextBlock Text="{Binding FrameRate, StringFormat={}{0}fps}" FontSize="10" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#1A00C1D4"/>
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Output Path -->
        <Border Grid.Row="3" Background="{StaticResource SecondaryBackground}" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Save To" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding FullOutputPath, Mode=OneWay}" IsReadOnly="True" 
                             Background="Black" Foreground="White" BorderBrush="#33FFFFFF"
                             Padding="10" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="📁" Command="{Binding BrowseLocationCommand}"
                            Style="{StaticResource ModernButton}" Width="40" Margin="10,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Action Button -->
        <Button Grid.Row="4" Content="Start Export" Height="50" FontSize="18" FontWeight="Bold"
                Style="{StaticResource ModernButton}" Click="Export_Click"/>
    </Grid>
</Window>
